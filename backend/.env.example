DATABASE_URL=sqlite:///./realhack_pilot.db
APP_ENV=dev
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===== LLM providers =====
# Set the provider you want to use as primary. The other becomes fallback.
# Values: openai | anthropic | mock
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_SMART=gpt-4o

# Anthropic (fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6
