## RealHack Pilot — PRODUCTION environment
## Copy this file to /opt/realhack-pilot/.env.production on the server and
## fill in the secrets. NEVER commit the populated file to git.
## File mode should be 600 (chmod 600) and owned by the realhack user.

# ===== Application =====
APP_ENV=production

# ===== Postgres =====
# Remote Postgres 14 on the dedicated DB VM rcapaydbpgr001. We connect as the
# `postgres` superuser today; the DB box's pg_hba.conf trusts this app server
# by IP so no password is needed. PHASE 2 HARDENING: before broader hackathon
# traffic, create a dedicated `realhack` role with a password, restrict it to
# only the `realhack_pilot` database, and update this URL to use it.
DATABASE_URL=postgresql+psycopg2://postgres@rcapaydbpgr001:5432/realhack_pilot

# ===== CORS =====
# The internal hostname(s) the frontend is served from. We share the box with
# Pulse and route by hostname; users will hit http://realhack.realpage.com.
# Add the HTTPS variant the moment the cert lands.
CORS_ORIGINS=http://realhack.realpage.com,http://localhost,http://127.0.0.1

# ===== LLM providers =====
LLM_PROVIDER=openai

OPENAI_API_KEY=PASTE_HERE
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_SMART=gpt-4o

ANTHROPIC_API_KEY=PASTE_HERE
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SMART=claude-sonnet-4-6

# ===== Microsoft Graph API =====
# Keep "mock" until HTTPS + MSAL.js are in place. The dashboard runs the
# Comms tab in simulation mode in the meantime; channel provisioning still
# works via the CLI (provision_team_channels.py) using device-code auth.
GRAPH_MODE=mock

AZURE_TENANT_ID=2c94bed6-d675-4d3d-a53b-7b461fd6acc2
AZURE_CLIENT_ID=4c55dc04-7f4b-4765-8ae5-bc69f52ab98e
AZURE_CLIENT_SECRET=PASTE_HERE

GRAPH_MAIL_FROM=RealHack@realpage.com
GRAPH_PARENT_TEAM_ID=8de12ada-4c6a-4e6a-aa1c-79dbc0d7f606
